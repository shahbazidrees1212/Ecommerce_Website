@model IEnumerable<Ecommerce_Website.Models.Category>

<div class="container-fluid admin-category-page">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 category-header">
        <h2 class="fw-bold mb-0">Categories</h2>

        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Category" asp-action="Create" class="btn btn-primary px-3">
                <i class="fa fa-plus me-1"></i> Add Category
            </a>
        }
    </div>

    <!-- TABLE CARD -->
    <div class="card category-card shadow-sm border-0">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">

                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Image</th>

                            @if (User.IsInRole("Admin"))
                            {
                                <th width="150" class="text-center">Action</th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Name</td>

                                    <td>
                                        <img src="@item.ImageUrl" class="category-img" />
                                    </td>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <td class="text-center">
                                            <a asp-controller="Category"
                                               asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-warning me-1">
                                                <i class="fa fa-edit"></i>
                                            </a>

                                            <a asp-controller="Category"
                                               asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-danger">
                                                <i class="fa fa-trash"></i>
                                            </a>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-4 text-muted">
                                    No categories found
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

    <!-- PAGINATION -->
    <nav class="mt-4">
        <ul class="pagination justify-content-center">

            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">

                    <a class="page-link"
                       asp-controller="Admin"
                       asp-action="Category"
                       asp-route-page="@i">
                        @i
                    </a>

                </li>
            }

        </ul>
    </nav>

</div>