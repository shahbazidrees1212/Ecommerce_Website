@model Ecommerce_Website.Models.Order

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">📦 Order Details #@Model.Id</h3>
        <a asp-action="Orders" class="btn btn-outline-secondary btn-sm">
            ← Back to Orders
        </a>
    </div>

    <!-- ORDER SUMMARY -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <div class="row">

                <div class="col-md-6">
                    <p>
                        <strong>Order Date:</strong>
                        @(Model.OrderDate != null ? Model.OrderDate.ToString("dd MMM yyyy") : "N/A")
                    </p>

                    <p>
                        <strong>Status:</strong>
                        <span class="badge px-3 py-2
                            @(Model.Status == "Pending" ? "bg-warning text-dark" :
                                                            Model.Status == "Processing" ? "bg-info" :
                                                            Model.Status == "Shipped" ? "bg-primary" :
                                                            Model.Status == "Delivered" ? "bg-success" :
                                                            "bg-secondary")">
                            @Model.Status
                        </span>
                    </p>
                </div>

                <div class="col-md-6 text-md-end">
                    <p>
                        <strong>Total Amount:</strong>
                        <span class="text-success fw-bold fs-5">
                            $@Model.TotalAmount
                        </span>
                    </p>

                    <p>
                        <strong>User ID:</strong>
                        <span class="text-muted">@Model.UserId</span>
                    </p>
                </div>

            </div>

        </div>
    </div>

    <!-- STATUS UPDATE -->
    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header bg-light fw-semibold">
            🔄 Update Order Status
        </div>

        <div class="card-body">

            <form asp-action="UpdateOrderStatus" method="post">

                <input type="hidden" name="orderId" value="@Model.Id" />

                <div class="row g-3 align-items-center">

                    <div class="col-md-6">
                        <select name="status" class="form-select">

                            <option value="Pending" selected="@(Model.Status == "Pending")">Pending</option>
                            <option value="Processing" selected="@(Model.Status == "Processing")">Processing</option>
                            <option value="Shipped" selected="@(Model.Status == "Shipped")">Shipped</option>
                            <option value="Delivered" selected="@(Model.Status == "Delivered")">Delivered</option>
                            <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Cancelled</option>

                        </select>
                    </div>

                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">
                            ✔ Update Status
                        </button>
                    </div>

                </div>

            </form>

        </div>
    </div>

    <!-- PRODUCTS -->
    <div class="card shadow-sm border-0">

        <div class="card-header bg-light fw-semibold">
            🛒 Ordered Products
        </div>

        <div class="table-responsive">

            <table class="table mb-0 align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Qty</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.OrderItems != null && Model.OrderItems.Any())
                    {
                        foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>@(item.Product?.Name ?? "N/A")</td>
                                <td>$@item.Price</td>
                                <td>@item.Quantity</td>
                                <td class="fw-semibold">$@(item.Price* item.Quantity)</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-3">
                                No items found
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>