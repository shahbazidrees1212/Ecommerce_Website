@model Ecommerce_Website.Models.Category

<div class="container-fluid edit-category-page">

    <div class="card shadow border-0">

        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">

            <h4 class="mb-0">Edit Category</h4>

            <a asp-action="Index" class="btn btn-light btn-sm">
                <i class="fa fa-arrow-left"></i> Back
            </a>

        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <!-- LEFT SIDE -->
                    <div class="col-md-8">

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>

                            <input asp-for="Name" class="form-control" />

                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label fw-semibold"></label>

                            <input asp-for="ImageUrl" class="form-control" />

                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                    </div>


                    <!-- RIGHT SIDE IMAGE -->
                    <div class="col-md-4 text-center">

                        <label class="form-label fw-semibold">Current Image</label>

                        <div class="border rounded p-3">

                            <img src="@Model.ImageUrl"
                                 width="160"
                                 style="object-fit:cover"
                                 class="rounded shadow-sm" />

                        </div>

                    </div>

                </div>

                <hr />

                <button type="submit" class="btn btn-warning text-dark">
                    <i class="fa fa-save me-1"></i> Update Category
                </button>

            </form>

        </div>

    </div>

</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}