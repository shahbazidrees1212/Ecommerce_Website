@model Ecommerce_Website.Models.Category

<div class="container-fluid delete-category-page">

    <div class="card shadow border-0" style="max-width:500px; margin:auto;">

        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Delete Category</h4>
        </div>

        <div class="card-body text-center">

            <div class="alert alert-warning">
                Are you sure you want to delete this category?
            </div>

            <h5 class="fw-semibold">@Model.Name</h5>

            <div class="border rounded p-3 my-3">

                <img src="@Model.ImageUrl"
                     width="160"
                     class="rounded shadow-sm"
                     style="object-fit:cover" />

            </div>

            <form asp-action="Delete" method="post">

                <input type="hidden" asp-for="Id" />

                <button type="submit" class="btn btn-danger">
                    <i class="fa fa-trash me-1"></i> Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>