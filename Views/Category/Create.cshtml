@model Ecommerce_Website.Models.Category

<div class="container-fluid create-category-page">

    <div class="card shadow border-0">

        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">

            <h4 class="mb-0">Add Category</h4>

            <a asp-action="Index" class="btn btn-light btn-sm">
                <i class="fa fa-arrow-left"></i> Back
            </a>

        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div class="row">

                    <!-- LEFT SIDE -->
                    <div class="col-md-8">

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>

                            <input asp-for="Name" class="form-control" />

                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label fw-semibold"></label>

                            <input asp-for="ImageUrl"
                                   class="form-control"
                                   oninput="previewImage()" />

                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                    </div>


                    <!-- RIGHT SIDE IMAGE PREVIEW -->
                    <div class="col-md-4 text-center">

                        <label class="form-label fw-semibold">Image Preview</label>

                        <div class="border rounded p-3">

                            <img id="imagePreview"
                                 src="/images/no-image.png"
                                 width="160"
                                 class="rounded shadow-sm"
                                 style="object-fit:cover" />

                        </div>

                    </div>

                </div>

                <hr />

                <button type="submit" class="btn btn-warning text-dark">
                    <i class="fa fa-save me-1"></i> Save Category
                </button>

            </form>

        </div>

    </div>

</div>


@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        function previewImage()
        {
            var url = document.querySelector('[name="ImageUrl"]').value;

            if(url)
            {
                document.getElementById("imagePreview").src = url;
            }
        }

    </script>

}