@using Microsoft.AspNetCore.Identity
@using Ecommerce_Website.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    ApplicationUser? user = null;
    string profilePic = "/images/default-user.png";

    if (SignInManager.IsSignedIn(User))
    {
        user = await UserManager.GetUserAsync(User);

        if (user != null && !string.IsNullOrEmpty(user.ProfilePicture))
        {
            profilePic = user.ProfilePicture;
        }
    }
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- BOOTSTRAP -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

    <!-- FONT AWESOME -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <!-- CUSTOM CSS -->
    <link rel="stylesheet" href="~/css/admin.css" />

</head>

<body>

    <div class="admin-wrapper">

        <!-- ================= SIDEBAR ================= -->

        <div class="sidebar">

            <h4>Admin Panel</h4>

            <a asp-controller="Admin" asp-action="Index">
                <i class="fa fa-home"></i> Dashboard
            </a>

            <a asp-controller="Admin" asp-action="Products">
                <i class="fa fa-box"></i> Products
            </a>

            <a asp-controller="Admin" asp-action="Category">
                <i class="fa fa-tags"></i> Categories
            </a>
            <a asp-controller="Admin" asp-action="Orders">
                <i class="fa fa-shopping-cart"></i> Orders
            </a>

            <a asp-controller="Admin" asp-action="Users">
                <i class="fa fa-users"></i> Users
            </a>

        </div>


        <!-- ================= MAIN CONTENT ================= -->

        <div class="main-content">

            <!-- ================= TOPBAR ================= -->

            <div class="topbar">

                <button class="menu-btn" onclick="toggleSidebar()">
                    <i class="fa fa-bars"></i>
                </button>

                <h5 class="mb-0">Admin Dashboard</h5>


                <!-- PROFILE -->

                <div class="dropdown">

                    <button class="btn profile-btn dropdown-toggle d-flex align-items-center"
                            type="button"
                            data-bs-toggle="dropdown">

                        <img src="@profilePic"
                             class="rounded-circle me-2"
                             width="32"
                             height="32"
                             style="object-fit:cover" />

                        @user?.Name

                        <span class="badge bg-warning text-dark ms-2">Admin</span>

                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow">

                        <li>
                            <a class="dropdown-item"
                                   asp-controller="Account"
                                   asp-action="Profile">

                                <i class="fa fa-user me-2"></i>
                                Admin Profile

                            </a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li>

                            <form asp-controller="Home"
                                  asp-action="Logout"
                                  method="post">

                                <button type="submit"
                                        class="dropdown-item text-danger">

                                    <i class="fa fa-sign-out-alt me-2"></i>
                                    Logout

                                </button>

                            </form>

                        </li>

                    </ul>

                </div>

            </div>

            <!-- PAGE CONTENT -->
            @RenderBody()

        </div>

    </div>


    <!-- BOOTSTRAP JS -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        function toggleSidebar(){
        document.querySelector(".sidebar").classList.toggle("show");
        }

    </script>

</body>
</html>