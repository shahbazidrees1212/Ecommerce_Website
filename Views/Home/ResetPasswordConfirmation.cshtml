<style>
    /* ================= BACKGROUND ================= */
    body {
        background: #f8fafc;
    }

    /* ================= WRAPPER (TOP SPACE FIX) ================= */
    .page-wrapper {
        padding-top: 20px;
        padding-bottom: 30px;
    }

    /* ================= CARD ================= */
    .success-card {
        border-radius: 18px;
        transition: 0.25s;
        border: none;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

        .success-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 40px rgba(0,0,0,0.1);
        }

    /* ================= ICON ================= */
    .icon-circle {
        width: 70px;
        height: 70px;
        background: #2563eb; /* 🔵 BLUE */
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* ================= BUTTON ================= */
    .btn-primary {
        background: #2563eb;
        border: none;
        color: #fff;
        font-weight: 600;
        transition: 0.25s;
    }

        .btn-primary:hover {
            background: #1e40af;
        }
</style>
<div class="page-wrapper">
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card success-card shadow p-4 text-center">

                <!-- ICON -->
                <div class="icon-circle mx-auto mb-3">
                    <i class="bi bi-check-circle-fill fs-2 text-dark"></i>
                </div>

                <!-- TITLE -->
                <h4 class="fw-bold mb-2">Password Reset Successful</h4>

                <!-- MESSAGE -->
                <p class="text-muted mb-4">
                    Your password has been updated successfully. You can now log in with your new credentials.
                </p>

                <!-- BUTTON -->
                <div class="d-grid">
                    <a asp-action="Login" asp-controller="Home" class="btn btn-primary btn-lg rounded-pill">
                        Go to Login
                    </a>
                </div>

            </div>

        </div>
    </div>
</div>
</div>