@model Ecommerce_Website.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<style>
    /* ================= BACKGROUND ================= */
    body {
        background: #f8fafc;
    }

    /* ================= WRAPPER (TOP SPACE FIX) ================= */
    .page-wrapper {
        padding-top: 30px; /* 👈 space from navbar */
        padding-bottom: 40px;
    }

    /* ================= CARD ================= */
    .card {
        border-radius: 18px;
        transition: 0.25s;
        border: none;
        box-shadow: 0 8px 25px rgba(0,0,0,0.05);
    }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

    /* ================= HEADER ================= */
    .card-header {
        background: #2563eb; /* 🔵 BLUE */
        color: #fff;
        border-top-left-radius: 18px;
        border-top-right-radius: 18px;
        font-weight: 600;
    }

    /* ================= INPUT ================= */
    .form-control {
        border-radius: 50px;
        padding: 10px 15px;
        border: 1px solid #e2e8f0;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.2);
        }

    /* ================= BUTTON ================= */
    .btn-primary {
        background: #2563eb;
        border: none;
        color: #fff;
        font-weight: 600;
        transition: 0.25s;
    }

        .btn-primary:hover {
            background: #1e40af; /* darker blue */
        }

    /* ================= INPUT GROUP BUTTON ================= */
    .input-group .btn {
        border-radius: 0 50px 50px 0 !important;
        background: #2563eb;
        color: #fff;
    }

        .input-group .btn:hover {
            background: #1e40af;
        }
</style>
<div class="page-wrapper">
<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center">

    <div class="card shadow border-0" style="max-width: 500px; width: 100%;">

        <!-- HEADER -->
        <div class="card-header text-center py-3">
            <h4 class="fw-bold mb-0">🔒 Reset Password</h4>
        </div>

        <!-- BODY -->
        <div class="card-body p-4">

            <p class="text-muted text-center mb-4">
                Enter your new password to secure your account
            </p>

            <form method="post" asp-action="ResetPassword" asp-controller="Home">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <!-- Hidden -->
                <input asp-for="Token" type="hidden" />
                <input asp-for="Email" type="hidden" />

                <!-- NEW PASSWORD -->
                <div class="mb-3">
                    <label asp-for="Password" class="fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control" id="passwordField" />
                        <button type="button" class="btn btn-outline-dark" onclick="togglePassword('passwordField','icon1')">
                            <i class="bi bi-eye-slash" id="icon1"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <!-- CONFIRM PASSWORD -->
                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" id="confirmField" />
                        <button type="button" class="btn btn-outline-dark" onclick="togglePassword('confirmField','icon2')">
                            <i class="bi bi-eye-slash" id="icon2"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <!-- BUTTON -->
                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary py-2">
                        Reset Password
                    </button>
                </div>

            </form>
        </div>

        <!-- FOOTER -->
        <div class="text-center py-3">
            <a asp-controller="Home" asp-action="Login" class="text-decoration-none text-muted">
                ← Back to Login
            </a>
        </div>

    </div>
</div>
</div>
@section Scripts {
    <script>
        function togglePassword(fieldId, iconId) {
            const field = document.getElementById(fieldId);
            const icon = document.getElementById(iconId);

            if (field.type === "password") {
                field.type = "text";
                icon.className = "bi bi-eye";
            } else {
                field.type = "password";
                icon.className = "bi bi-eye-slash";
            }
        }
    </script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
}