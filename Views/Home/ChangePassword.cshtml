@model Ecommerce_Website.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<style>
    /* Background */
    body {
        background: #f1f5f9;
    }

    /* Card */
    .card {
        border-radius: 18px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    /* Icon */
    .icon-circle {
        width: 65px;
        height: 65px;
        background: linear-gradient(135deg, #6366f1, #9333ea);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Inputs */
    .form-control {
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #e5e7eb;
        transition: 0.3s;
    }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 8px rgba(99,102,241,0.3);
        }

    /* Input Group Button */
    .input-group .btn {
        border-radius: 0 12px 12px 0 !important;
        background: #6366f1;
        color: #fff;
        border: none;
    }

        .input-group .btn:hover {
            background: #4f46e5;
        }

    /* Primary Button */
    .btn-primary {
        background: linear-gradient(135deg, #6366f1, #9333ea);
        border: none;
        border-radius: 12px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-primary:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 20px rgba(99,102,241,0.3);
        }

    /* Labels */
    label {
        font-weight: 500;
        margin-bottom: 5px;
    }

    /* Success Alert */
    .alert-success {
        border-radius: 12px;
        background: #dcfce7;
        color: #166534;
        border: none;
    }
</style>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success text-center mt-3">
        @TempData["SuccessMessage"]
    </div>
}

<div class="d-flex justify-content-center align-items-center py-5 mt-5">

    <div class="card shadow p-4 p-md-5" style="max-width: 500px; width:100%;">

        <!-- HEADER -->
        <div class="text-center mb-4">
            <div class="icon-circle mx-auto mb-3">
                <i class="fa-solid fa-lock text-white fs-5"></i>
            </div>
            <h4 class="fw-bold mb-1">Change Password</h4>
            <p class="text-muted small">Keep your account secure</p>
        </div>

        <!-- FORM -->
        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- EMAIL -->
            <div class="mb-3">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" readonly />
            </div>

            <!-- CURRENT PASSWORD -->
            <div class="mb-3">
                <label asp-for="CurrentPassword"></label>
                <div class="input-group">
                    <input asp-for="CurrentPassword" type="password" class="form-control" id="currentPassword" />
                    <button type="button" class="btn btn-outline-dark" onclick="togglePassword('currentPassword','icon1')">
                        <i class="bi bi-eye-slash" id="icon1"></i>
                    </button>
                </div>
            </div>

            <!-- NEW PASSWORD -->
            <div class="mb-3">
                <label asp-for="NewPassword"></label>
                <div class="input-group">
                    <input asp-for="NewPassword" type="password" class="form-control" id="newPassword" />
                    <button type="button" class="btn btn-outline-dark" onclick="togglePassword('newPassword','icon2')">
                        <i class="bi bi-eye-slash" id="icon2"></i>
                    </button>
                </div>
            </div>

            <!-- CONFIRM PASSWORD -->
            <div class="mb-4">
                <label asp-for="ConfirmPassword"></label>
                <div class="input-group">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" id="confirmPassword" />
                    <button type="button" class="btn btn-outline-dark" onclick="togglePassword('confirmPassword','icon3')">
                        <i class="bi bi-eye-slash" id="icon3"></i>
                    </button>
                </div>
            </div>

            <!-- BUTTON -->
            <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="fa-solid fa-key me-2"></i> Update Password
            </button>

        </form>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(fieldId, iconId) {
            const field = document.getElementById(fieldId);
            const icon = document.getElementById(iconId);

            if (field.type === "password") {
                field.type = "text";
                icon.className = "bi bi-eye";
            } else {
                field.type = "password";
                icon.className = "bi bi-eye-slash";
            }
        }
    </script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
}