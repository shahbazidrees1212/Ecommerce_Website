@model IEnumerable<Ecommerce_Website.Models.Product>

<div class="product-page">
    <div class="container py-5">

        <!-- HEADER -->
        <div class="header-section">

            <!-- 🔷 TITLE -->
            <h2 class="page-title">Our Products</h2>
            <p class="page-subtitle">Browse and explore our latest collection</p>

            <!-- 🔍 SEARCH -->
            <form method="get" asp-action="Index" asp-controller="Product">

                <div class="search-container">

                    <input type="text"
                           name="search"
                           value="@ViewBag.Search"
                           placeholder="Search products..." />

                    <button type="submit">
                        🔍
                    </button>

                </div>

            </form>

        </div>

    <!-- ❌ NO DATA -->
    @if (!Model.Any())
    {
        <div class="text-center text-danger fw-bold mt-4">
            No products found for "@ViewBag.Search"
        </div>
    }

    <!-- 🛍 PRODUCTS GRID -->
    <div class="row g-4 mt-2">

        @foreach (var product in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">

                <div class="product-card-modern">

                    <!-- IMAGE -->
                    <div class="product-img-wrapper">

                        <img src="@product.ImageUrl" />

                        <!-- BADGE -->
                        <span class="product-badge">New</span>

                        <!-- 🔥 HOVER BUTTON -->
                        <div class="product-hover">

                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@product.Id"
                               class="view-btn">

                                View Details

                            </a>

                        </div>

                    </div>

                    <!-- INFO -->
                    <div class="product-info">

                        <h6>@product.Name</h6>

                        <p class="price">$@product.Price</p>

                    </div>

                </div>

            </div>
        }

    </div>

    <!-- 📄 PAGINATION -->
    <nav class="mt-5">

        <ul class="pagination justify-content-center">

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                    <a class="page-link"
                       asp-action="Index"
                       asp-controller="Product"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search">

                        @i

                    </a>

                </li>
            }

        </ul>

    </nav>

</div>
</div>


