<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Shop</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg shadow-sm">
            <div class="container">

                <!-- Logo -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-cart-shopping"></i> E-Shop
                </a>

                <button class="navbar-toggler bg-light"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarMain">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse" id="navbarMain">

                    <!-- Left Menu -->

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">Products</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Category" asp-action="Index">Categories</a>
                        </li>

                    </ul>

                    <!-- Search -->
                    <form class="d-flex me-3 search-box"
                          method="get"
                          asp-action="Index"
                          asp-controller="Home">

                        <input class="form-control"
                               type="search"
                               name="search"
                               value="@ViewBag.Search"
                               placeholder="Search products...">

                        <button class="btn btn-warning ms-2" type="submit">
                            <i class="fa fa-search"></i>
                        </button>

                    </form>
                    <!-- Login Partial -->

                    <partial name="_LoginPartial" />

                </div>

            </div>
        </nav>

    </header>


    <!-- Main Content -->

    <main class="container-fluid p-0">
        @RenderBody()
    </main>

    <!-- Footer -->

    <footer class="mt-5 pt-5 pb-3">

        <div class="container">

            <div class="row g-5">

                <div class="col-md-4">

                    <h5>E-Shop</h5>

                    <p>
                        Your trusted ecommerce store for electronics,
                        fashion and everyday products.
                        Shop with confidence and fast delivery.
                    </p>

                </div>


                <div class="col-md-4">

                    <h5>Quick Links</h5>

                    <ul class="list-unstyled">

                        <li>
                            <a asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li>
                            <a asp-controller="Product" asp-action="Index">Products</a>
                        </li>

                        <li>
                            <a asp-controller="Category" asp-action="Index">Categories</a>
                        </li>

                    </ul>

                </div>


                <div class="col-md-4">

                    <h5>Contact</h5>

                    <p><i class="fa fa-envelope"></i> support@eshop.com</p>

                    <p><i class="fa fa-phone"></i> +92 300 1234567</p>

                    <p><i class="fa fa-location-dot"></i> Karachi, Pakistan</p>

                </div>

            </div>

            <hr class="bg-light">

            <div class="text-center">

                <p class="mb-0">

                    © 2026 E-Shop. All Rights Reserved.

                </p>

            </div>

        </div>

    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>