@model IEnumerable<Ecommerce_Website.Models.Category>

<section class="categories-section">
    <div class="container">

        <!-- HEADER -->
        <div class="category-header text-center">
            <p class="explore-text">EXPLORE</p>
            <h1 class="categories-title">Categories</h1>
        </div>

        <!-- GRID -->
        @if (Model != null && Model.Any())
        {
            var categories = Model.Take(4).ToList();

            <div class="row g-4">

                @for (int i = 0; i < categories.Count; i++)
                {
                    var cat = categories[i];

                    <div class="col-md-6">

                        <a asp-controller="Product"
                           asp-action="Index"
                           asp-route-categoryId="@cat.Id"
                           class="category-link">

                            <!-- CARD -->
                            <div class="category-card @(i < 2 ? "large-card" : "small-card")">

                                <!-- IMAGE -->
                                <img src="@cat.ImageUrl"
                                     class="category-img"
                                     loading="lazy"
                                     alt="@cat.Name" />

                                <!-- OVERLAY -->
                                <div class="overlay"></div>

                                <!-- CONTENT -->
                                <div class="content">
                                    <h3>@cat.Name</h3>
                                    <p>@(cat.Products?.Count ?? 0) products</p>
                                </div>

                            </div>

                        </a>

                    </div>
                }

            </div>
        }
        else
        {
            <div class="text-center py-5">
                <p class="text-muted">No categories found</p>
            </div>
        }

        <!-- PAGINATION -->
        <nav class="mt-5">
            <ul class="pagination justify-content-center custom-pagination">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>

    </div>
</section>