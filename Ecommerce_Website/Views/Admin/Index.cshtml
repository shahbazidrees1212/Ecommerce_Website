@{
    Layout = "_AdminLayout";
}

<style>
    /* ================================
    IMPROVED EXISTING THEME
    ================================ */

    /* Smooth UI feel */
    * {
        transition: all 0.25s ease;
    }

    /* ================================
    STAT CARDS (ENHANCED)
    ================================ */
    .stat-card {
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        background: #ffffff;
        position: relative;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08);
        }

        /* subtle top border highlight */
        .stat-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            height: 4px;
            width: 100%;
            background: linear-gradient(to right, #0d6efd, #6610f2);
        }

    /* ================================
    ICON STYLE (BETTER)
    ================================ */
    .stat-icon {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        box-shadow: 0 5px 12px rgba(0,0,0,0.1);
    }

    /* ================================
    DASHBOARD CARDS (CLICKABLE)
    ================================ */
    .dashboard-card {
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        background: #fff;
        position: relative;
        overflow: hidden;
    }

        .dashboard-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

        /* hover glow effect */
        .dashboard-card::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent, rgba(13,110,253,0.1), transparent);
            opacity: 0;
        }

        .dashboard-card:hover::after {
            opacity: 1;
        }

    /* ================================
    TABLE IMPROVEMENT
    ================================ */
    .table {
        border-radius: 12px;
        overflow: hidden;
    }

        .table thead {
            background: #f1f5f9;
        }

            .table thead th {
                font-size: 13px;
                text-transform: uppercase;
                color: #64748b;
                border-bottom: none;
            }

        .table tbody tr:hover {
            background: #f9fafb;
        }

    /* ================================
    LOW STOCK LIST
    ================================ */
    .list-group-item {
        border-radius: 10px !important;
        border: 1px solid #f1f5f9;
        margin-bottom: 6px;
    }

        .list-group-item:hover {
            background: #f8fafc;
        }

    /* ================================
    HEADINGS
    ================================ */
    h2 {
        font-weight: 700;
    }

    h5 {
        font-weight: 600;
    }
</style>

<div class="container-fluid mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Admin Dashboard</h2>
            <p class="text-muted mb-0">Welcome back 👋</p>
        </div>
    </div>

    <!-- STATS -->
    <div class="row g-4 mb-4">

        <!-- Products -->
        <div class="col-lg-3 col-md-6">
            <div class="card stat-card p-3 shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted mb-1">Products</p>
                        <h3 class="fw-bold mb-0">@ViewBag.ProductsCount ?? 0</h3>
                    </div>
                    <div class="stat-icon bg-primary">
                        <i class="fa fa-box"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Categories -->
        <div class="col-lg-3 col-md-6">
            <div class="card stat-card p-3 shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted mb-1">Categories</p>
                        <h3>@ViewBag.CategoriesCount ?? 0</h3>
                    </div>
                    <div class="stat-icon bg-success">
                        <i class="fa fa-tags"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Orders -->
        <div class="col-lg-3 col-md-6">
            <div class="card stat-card p-3 shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted mb-1">Orders</p>
                        <h3>@ViewBag.OrdersCount ?? 0</h3>
                    </div>
                    <div class="stat-icon bg-warning">
                        <i class="fa fa-shopping-cart"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Users -->
        <div class="col-lg-3 col-md-6">
            <div class="card stat-card p-3 shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted mb-1">Users</p>
                        <h3>@ViewBag.UsersCount ?? 0</h3>
                    </div>
                    <div class="stat-icon bg-danger">
                        <i class="fa fa-users"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Revenue -->
        <div class="col-lg-3 col-md-6">
            <div class="card stat-card p-3 shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted mb-1">Revenue</p>
                        <h3>$@ViewBag.TotalRevenue</h3>
                    </div>
                    <div class="stat-icon bg-dark">
                        <i class="fa fa-dollar-sign"></i>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- MANAGEMENT -->
    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="Products" class="text-decoration-none">
                <div class="dashboard-card card p-4 text-center shadow-sm">
                    <i class="fa fa-box fa-2x text-primary mb-2"></i>
                    <h6 class="fw-bold">Products</h6>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="Category" class="text-decoration-none">
                <div class="dashboard-card card p-4 text-center shadow-sm">
                    <i class="fa fa-tags fa-2x text-success mb-2"></i>
                    <h6 class="fw-bold">Categories</h6>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="Orders" class="text-decoration-none">
                <div class="dashboard-card card p-4 text-center shadow-sm">
                    <i class="fa fa-shopping-cart fa-2x text-warning mb-2"></i>
                    <h6 class="fw-bold">Orders</h6>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="Users" class="text-decoration-none">
                <div class="dashboard-card card p-4 text-center shadow-sm">
                    <i class="fa fa-users fa-2x text-danger mb-2"></i>
                    <h6 class="fw-bold">Users</h6>
                </div>
            </a>
        </div>

    </div>

    <!-- RECENT ORDERS -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="fw-semibold mb-3">Recent Orders</h5>

            @if (ViewBag.RecentOrders != null && ViewBag.RecentOrders.Count > 0)
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Total</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in ViewBag.RecentOrders)
                        {
                            <tr>
                                <td>@order.Id</td>
                                <td>$@order.TotalAmount</td>
                                <td>@order.OrderDate.ToString("dd MMM yyyy")</td> <!-- ✅ FIX -->
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">No recent orders</p>
            }
        </div>
    </div>

    <!-- LOW STOCK -->
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="fw-bold text-danger">Low Stock Products</h5>

            @if (ViewBag.LowStock != null && ViewBag.LowStock.Count > 0)
            {
                <ul class="list-group">
                    @foreach (var item in ViewBag.LowStock)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            @item.Name
                            <span class="badge bg-danger">@item.Stock left</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">All products are in stock ✅</p>
            }
        </div>
    </div>

</div>