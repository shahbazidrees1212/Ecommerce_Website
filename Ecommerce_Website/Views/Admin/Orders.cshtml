@model IEnumerable<Ecommerce_Website.Models.Order>

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📊 Admin Order Management</h2>
        <span class="text-muted">Manage and track all orders</span>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>User</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var order in Model)
                            {
                                <tr>

                                    <td><strong>#@order.Id</strong></td>

                                    <td>
                                        <span class="text-muted">@order.UserId</span>
                                    </td>

                                    <td>
                                        @(order.OrderDate != null
                                                                        ? order.OrderDate.ToString("dd MMM yyyy")
                                                                        : "N/A")
                                                                            </td>

                                    <td>
                                        <span class="fw-semibold text-success">
                                            $@order.TotalAmount
                                        </span>
                                    </td>

                                    <!-- STATUS -->
                                    <td>
                                        <span class="badge px-3 py-2
                                                    @(order.Status == "Pending" ? "bg-warning text-dark" :
                                                                                            order.Status == "Confirmed" ? "bg-info" :
                                                                                            order.Status == "Shipped" ? "bg-primary" :
                                                                                            order.Status == "Delivered" ? "bg-success" :
                                                                                            order.Status == "Cancelled" ? "bg-danger" :
                                                                                            "bg-secondary")">
                                    @order.Status
                                </span>
                            </td>

                                    <!-- ACTION -->
                                    <td class="text-center">
                                        <a asp-controller="Admin"
                                           asp-action="OrderDetails"
                                           asp-route-id="@order.Id"
                                           class="btn btn-sm btn-outline-dark">
                                            👁 View
                                        </a>
                                    </td>

                                </tr>
                                                }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    No orders found
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    </div>

    <!-- 🔥 PAGINATION -->
    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">

                <!-- Previous -->
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Orders"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                        «
                    </a>
                </li>

                <!-- Numbers -->
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Orders"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <!-- Next -->
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Orders"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                        »
                    </a>
                </li>

            </ul>
        </nav>
    }

</div>