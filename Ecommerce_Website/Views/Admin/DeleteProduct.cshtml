@model Ecommerce_Website.Models.Product

<div class="container-fluid delete-product-page">

    <div class="card shadow border-0">

        <div class="card-header bg-danger text-white">

            <h4 class="mb-0">Delete Product</h4>

        </div>

        <div class="card-body text-center">

            <h5 class="mb-3">Are you sure you want to delete this product?</h5>

            <img src="@Model.ImageUrl"
                 width="150"
                 class="mb-3 rounded shadow" />

            <h5>@Model.Name</h5>

            <p class="text-muted">$@Model.Price</p>

            <form asp-action="DeleteProduct" method="post">

                <input type="hidden" asp-for="Id" />

                <button class="btn btn-danger">
                    <i class="fa fa-trash me-1"></i> Delete
                </button>

                <a asp-action="Products" class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>